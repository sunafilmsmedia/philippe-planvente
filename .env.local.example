# ─────────────────────────────────────────────────────────────
# Variables par courtier — à définir sur Vercel pour chaque déploiement.
# ─────────────────────────────────────────────────────────────

# Optionnel — sans clé, l'app génère un plan déterministe (fallback).
ANTHROPIC_API_KEY=

# CRM GoHighLevel — sans webhook, les leads sont logés côté serveur.
# Reçoit uniquement les leads qualifiés (verdict offensif / stratégique).
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# Tracking (client) — laisser vide pour désactiver.
# IMPORTANT : ne jamais réutiliser l'ID d'un autre courtier.
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
